# Copy to .env and fill in one provider key. The selector routes to whichever
# model the task is configured for; set the matching provider's key.
#   cp .env.example .env

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override the model used for a task at runtime, no code change needed.
# Value must be a model id registered in order_agent/models.py.
# MODEL_ORDER_EXTRACTION=gpt-4o
# MODEL_CLARIFICATION=claude-haiku-4-5
